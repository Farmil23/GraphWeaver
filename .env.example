# ── DOKU Payment ──────────────────────────────────────────────
DOKU_CLIENT_ID=BRN-xxxx-xxxxxxxxxxxxxxx
DOKU_SECRET_KEY=SK-xxxxxxxxxxxxxxxxxxxxxxx
